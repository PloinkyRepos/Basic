{
  "tools": [
    {
      "name": "sandbox_exec",
      "title": "Sandbox Exec",
      "description": "Run a bounded command inside a nested bubblewrap sandbox. Stdin and small staged files can be supplied. Network is disabled by default. Output is truncated to configured caps.",
      "command": "/code/bin/sandbox-exec.mjs",
      "cwd": "/code",
      "timeoutMs": 130000,
      "inputSchema": {
        "command": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "description": "Shell command to execute inside the sandbox via /bin/sh -lc."
        },
        "stdin": {
          "type": "string",
          "optional": true,
          "maxLength": 1048576,
          "description": "Optional standard input to feed to the command."
        },
        "timeoutMs": {
          "type": "number",
          "optional": true,
          "min": 100,
          "max": 120000,
          "description": "Maximum runtime in milliseconds. Capped server-side."
        },
        "env": {
          "type": "object",
          "optional": true,
          "additionalProperties": true,
          "description": "Optional environment overrides. Only allowlisted keys are forwarded; values are validated."
        },
        "files": {
          "type": "array",
          "optional": true,
          "maxItems": 64,
          "description": "Optional files to stage under /work before command execution. Paths must be relative and normalized.",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              },
              "content": {
                "type": "string"
              },
              "encoding": {
                "type": "string",
                "optional": true,
                "enum": [
                  "utf8",
                  "base64"
                ]
              }
            }
          }
        },
        "runtimeBundle": {
          "type": "object",
          "optional": true,
          "description": "Optional provider-owned runtime bundle to bind read-only at /runtime. Resolved under BWRAP_RUNNER_RUNTIME_ROOT (default /data/research-runtimes).",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "description": "Bundle id (lowercase alnum plus ._-)."
            },
            "version": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "description": "Bundle version (lowercase alnum plus ._-)."
            },
            "digest": {
              "type": "string",
              "optional": true,
              "maxLength": 256,
              "description": "Optional manifest digest to require."
            }
          }
        }
      }
    }
  ]
}
